---
import { fade } from 'astro:transitions';
import type { ShopProduct } from '../../lib/shop';
import { formatPrice } from '../../lib/shop-format';
import { productDisplayPrice, productHandle, productImageUrl, productSearchText } from '../../lib/shop';
import type { ProductOption } from '../../lib/shop-options';
import type { StorefrontVariant } from '../../lib/shopify-storefront';
import ShopCardQuickBuy from './ShopCardQuickBuy.astro';

interface Props {
  product: ShopProduct;
  variants?: StorefrontVariant[];
  options?: ProductOption[];
}

const { product, variants = [], options } = Astro.props;
const title = product.store?.title ?? 'Untitled product';
const handle = productHandle(product);
const imageUrl = productImageUrl(product);
const price = productDisplayPrice(product);
const searchText = productSearchText(product);
const href = handle ? `/shop/${handle}` : undefined;
const quickBuyId = product._id;
---

<article
  class:list={['page-shop-card', { 'has-link': Boolean(href) }]}
  data-shop-product-card
  data-shop-search-text={searchText}
  transition:animate={fade({ duration: '600ms' })}
>
  {href ? <a class="page-shop-card-link" href={href} aria-label={title} /> : null}

  <div class="page-shop-card-header">
    <span class="page-shop-card-title" data-shop-product-title>
      {title}
    </span>
    {typeof price === 'number' ? (
      <span class="page-shop-card-price">{formatPrice(price)}</span>
    ) : null}
  </div>

  <div class="page-shop-card-media">
    {imageUrl ? <img src={imageUrl} alt="" loading="lazy" /> : null}
  </div>

  {
    variants.length > 0 ? (
      <ShopCardQuickBuy variants={variants} options={options} buyId={quickBuyId} />
    ) : null
  }
</article>
