---
import { fade } from 'astro:transitions';
import type { ShopProduct } from '../../lib/shop';
import { formatEurPrice } from '../../lib/shop-format';
import { productDisplayPrice, productHandle, productImageUrl } from '../../lib/shop';

interface Props {
  product: ShopProduct;
}

const { product } = Astro.props;
const title = product.store?.title ?? 'Untitled product';
const handle = productHandle(product);
const imageUrl = productImageUrl(product);
const price = productDisplayPrice(product);
const href = handle ? `/shop/${handle}` : undefined;
---

{
  href ? (
    <a
      class="page-shop-card"
      href={href}
      data-shop-product-card
      transition:animate={fade({ duration: '600ms' })}
    >
      <div class="page-shop-card-header">
        <span class="page-shop-card-title" data-shop-product-title>
          {title}
        </span>
        {typeof price === 'number' ? (
          <span class="page-shop-card-price">{formatEurPrice(price)}</span>
        ) : null}
      </div>
      {imageUrl ? (
        <div class="page-shop-card-media">
          <img src={imageUrl} alt={title} loading="lazy" />
        </div>
      ) : (
        <div class="page-shop-card-media" aria-hidden="true" />
      )}
    </a>
  ) : (
    <article class="page-shop-card" data-shop-product-card>
      <div class="page-shop-card-header">
        <span class="page-shop-card-title" data-shop-product-title>
          {title}
        </span>
        {typeof price === 'number' ? (
          <span class="page-shop-card-price">{formatEurPrice(price)}</span>
        ) : null}
      </div>
      {imageUrl ? (
        <div class="page-shop-card-media">
          <img src={imageUrl} alt={title} loading="lazy" />
        </div>
      ) : (
        <div class="page-shop-card-media" aria-hidden="true" />
      )}
    </article>
  )
}
