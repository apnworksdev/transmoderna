---
import { fade } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="page-shop-product-toolbar">
  <div class="page-shop-product-toolbar-title-wrap">
    <h1 class="page-shop-product-toolbar-title">{title}</h1>
  </div>

  <a
    class="page-shop-product-toolbar-close site-header-pill site-close-pill"
    href="/shop"
    transition:animate={fade({ duration: '600ms' })}
  >
    Close
  </a>
</div>
