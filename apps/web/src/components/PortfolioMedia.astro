---
import type { PortfolioItemDocument } from '../lib/sanity';
import SanityImage from './SanityImage.astro';
import VimeoEmbed from './VimeoEmbed.astro';

interface Props {
  media?: PortfolioItemDocument['media'];
  title: string;
}

const { media, title } = Astro.props;
---

{
  media?.kind === 'image' && media.image ? (
    <SanityImage image={media.image} altFallback={title} />
  ) : media?.kind === 'vimeo' && media.vimeo?.url ? (
    <VimeoEmbed url={media.vimeo.url} title={media.vimeo.title ?? title} />
  ) : null
}
