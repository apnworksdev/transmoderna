---
import {
  formatPodcastDate,
  formatPodcastNumber,
  imageAlt,
  urlForSanityImage,
  type PodcastDocument
} from '../../lib/sanity';

interface Props {
  podcast: PodcastDocument;
  variant?: 'index' | 'detail';
}

const { podcast, variant = 'index' } = Astro.props;

const title = podcast.title ?? 'Podcast';
const podcaster = podcast.podcaster ?? '';
const episodeNumber = formatPodcastNumber(podcast.number);
const publishDate = formatPodcastDate(podcast.publishDate);
const slug = podcast.slug?.current;
const detailHref = slug ? `/podcasts/${slug}` : undefined;
const hasAudio = Boolean(podcast.audioFileUrl);
const playerBackgroundSrc = urlForSanityImage(podcast.playerBackgroundImage, { width: 1600 });
const playerBackgroundAlt = imageAlt(podcast.playerBackgroundImage, title);
---

<div
  class:list={['podcast-player-bar', { 'podcast-player-bar--detail': variant === 'detail' }]}
  transition:animate="none"
  data-podcast-row
  data-audio-src={podcast.audioFileUrl ?? ''}
  data-podcast-id={podcast._id}
>
  {
    playerBackgroundSrc ? (
      <div class="podcast-player-bar__bg" aria-hidden="true">
        <img src={playerBackgroundSrc} alt={playerBackgroundAlt} loading="eager" decoding="async" />
      </div>
    ) : null
  }

  <span class="podcast-player-bar__number">{episodeNumber}</span>

  <div class="podcast-player-bar__copy">
    <span class="podcast-player-bar__series podcast-player-bar__series--plain">{podcaster}</span>
    <span class="podcast-player-bar__title">{title}</span>
  </div>

  <button
    type="button"
    class="podcast-player-bar__control podcast-player-bar__play"
    data-podcast-play-toggle
    disabled={!hasAudio}
    aria-label={`Play ${title}`}
  >
    <span class="podcast-player-bar__play-label" data-podcast-play-label>PLAY</span>
    <svg
      class="podcast-player-bar__play-icon podcast-player-bar__play-icon--play"
      width="22"
      height="22"
      viewBox="0 0 10 10"
      aria-hidden="true"
    >
      <path d="M3.25 2.25L7.25 5L3.25 7.75V2.25Z" fill="currentColor"></path>
    </svg>
    <svg
      class="podcast-player-bar__play-icon podcast-player-bar__play-icon--pause"
      width="22"
      height="22"
      viewBox="0 0 10 10"
      aria-hidden="true"
    >
      <rect x="2.75" y="2.25" width="1.5" height="5.5" fill="currentColor"></rect>
      <rect x="5.75" y="2.25" width="1.5" height="5.5" fill="currentColor"></rect>
    </svg>
  </button>

  <button
    type="button"
    class="podcast-player-bar__progress"
    data-podcast-progress
    aria-label="Audio progress"
    aria-valuemin={0}
    aria-valuemax={100}
    aria-valuenow={0}
    disabled={!hasAudio}
  >
    <span class="podcast-player-bar__progress-track">
      <span class="podcast-player-bar__progress-fill" data-podcast-progress-fill />
    </span>
  </button>

  <button
    type="button"
    class="podcast-player-bar__control podcast-player-bar__mute"
    data-podcast-mute-toggle
    aria-pressed="false"
    disabled={!hasAudio}
  >
    MUTE
  </button>

  <span class="podcast-player-bar__elapsed" data-podcast-elapsed>00:00:00</span>

  <time class="podcast-player-bar__date" datetime={podcast.publishDate ?? undefined}>
    {publishDate}
  </time>

  {
    variant === 'detail' ? (
      <button type="button" class="podcast-player-bar__control" data-podcast-share>
        SHARE
      </button>
    ) : detailHref ? (
      <a class="podcast-player-bar__control podcast-player-bar__view" href={detailHref}>
        VIEW
      </a>
    ) : (
      <span class="podcast-player-bar__control podcast-player-bar__view podcast-player-bar__view--disabled">
        VIEW
      </span>
    )
  }
</div>
