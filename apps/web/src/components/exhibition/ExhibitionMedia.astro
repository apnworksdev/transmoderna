---
import type { ExhibitionMedia } from '../../lib/sanity';
import HtmlVideo from '../HtmlVideo.astro';
import SanityImage from '../SanityImage.astro';
import VimeoEmbed from '../VimeoEmbed.astro';

interface Props {
  media?: ExhibitionMedia;
  title: string;
  imageWidth?: number;
}

const { media, title, imageWidth = 1200 } = Astro.props;
const showImage = media?.kind === 'image' && media.image;
const showVideo = media?.kind === 'video' && media.videoUrl;
---

{
  showImage ? (
    <SanityImage image={media?.image} altFallback={title} width={imageWidth} />
  ) : showVideo ? (
    media?.videoSrc ? (
      <HtmlVideo src={media.videoSrc} title={title} />
    ) : (
      <VimeoEmbed url={media?.videoUrl} title={title} />
    )
  ) : null
}
