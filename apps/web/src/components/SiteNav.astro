---
const links = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/exhibitions', label: 'Exhibitions' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/podcasts', label: 'Podcasts' },
  { href: '/shop', label: 'Shop' },
  { href: '/about', label: 'About' }
];
---

<nav aria-label="Main">
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))
    }
  </ul>
</nav>
