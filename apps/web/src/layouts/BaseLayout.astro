---
import SiteHeader from '../components/SiteHeader.astro';
import { getHome, getSiteHeader } from '../lib/sanity';
import type { SanityImageWithAlt, SiteMenuLink } from '../lib/sanity';
import {
  HOME_INTRO_SESSION_KEY,
  HOME_INTRO_SESSION_VALUE,
  SITE_MENU_FALLBACK_LINKS
} from '@repo/shared';
import { ClientRouter, fade } from 'astro:transitions';
import '../styles/index.css';
import '../styles/components/fixed-footer.css';
import '../styles/components/nav.css';
import '../styles/components/page-transitions.css';

export type FixedFooterSize = 'big' | 'small' | 'hidden';

interface Props {
  title?: string;
  /** Index: full-screen home with intro sequence. */
  variant?: 'default' | 'index';
  /** Hide the global site header (e.g. exhibition detail). */
  hideSiteHeader?: boolean;
  /** Home footer logo — pass from index to avoid a duplicate Sanity fetch. */
  footerLogo?: SanityImageWithAlt | null;
  /** Fixed bottom bar height. Use the `fixedFooter` slot for its content. */
  fixedFooter?: FixedFooterSize;
}

const {
  title = 'Transmoderna',
  variant = 'default',
  hideSiteHeader = false,
  footerLogo: footerLogoProp,
  fixedFooter = 'hidden'
} = Astro.props;
const isIndex = variant === 'index';
const siteHeader = await getSiteHeader();

let footerLogo = footerLogoProp;
if (footerLogo === undefined) {
  const home = await getHome();
  footerLogo = home?.logo ?? null;
}

const menuFallback: SiteMenuLink[] = SITE_MENU_FALLBACK_LINKS.map((link) => ({
  ...link,
  image: null
}));

const menuLinks =
  siteHeader?.menuLinks && siteHeader.menuLinks.length > 0
    ? siteHeader.menuLinks
    : menuFallback;

if (isIndex) {
  await import('../styles/pages/index.css');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter fallback="animate" />
    <slot name="head" />
    {
      isIndex ? (
        <script
          is:inline
          define:vars={{ homeIntroKey: HOME_INTRO_SESSION_KEY, homeIntroValue: HOME_INTRO_SESSION_VALUE }}
        >
          try {
            if (sessionStorage.getItem(homeIntroKey) === homeIntroValue) {
              document.documentElement.classList.add('intro-complete');
            } else {
              document.documentElement.classList.add('intro-pending');
            }
          } catch (e) {
            document.documentElement.classList.add('intro-complete');
          }
        </script>
      ) : null
    }
  </head>
  <body
    transition:animate={fade({ duration: '600ms' })}
    class:list={[
      { 'page-index': isIndex },
      { 'page-exhibition-detail': hideSiteHeader },
      fixedFooter === 'small' ? 'fixed-footer-small' : null,
      fixedFooter === 'big' ? 'fixed-footer-big' : null
    ]}
  >
    {
      hideSiteHeader ? null : (
        <SiteHeader
          logo={siteHeader?.logo}
          menuLinks={menuLinks}
          footerLogo={footerLogo}
          deferChromeReveal={isIndex}
        />
      )
    }

    <slot />

    {
      fixedFooter !== 'hidden' ? (
        <div class="site-fixed-footer" data-fixed-footer={fixedFooter}>
          <slot name="fixedFooter" />
        </div>
      ) : null
    }

    <script>
      import '../scripts/init.ts';
    </script>
  </body>
</html>
