---
import SiteNav from '../components/SiteNav.astro';

interface Props {
  title?: string;
}

const { title = 'Transmoderna' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <SiteNav />
    <slot />
  </body>
</html>
