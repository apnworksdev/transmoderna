---
import SanityImage from '../components/SanityImage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHome } from '../lib/sanity';

const home = await getHome();
const introText = home?.introText?.trim() ?? '';
---

<BaseLayout title="Transmoderna" variant="index" footerLogo={home?.logo ?? null}>
  <div class="page-index-shell" data-home-page data-intro-text={introText}>
    <div class="page-index-video">
      <video
        title="Transmoderna"
        muted
        autoplay
        loop
        playsinline
        preload="auto"
      >
        <source src="/video/home-desktop.mp4" media="(min-width: 768px)" type="video/mp4" />
        <source src="/video/home-mobile.mp4" media="(max-width: 767px)" type="video/mp4" />
      </video>
    </div>

    {
      introText ? (
        <p class="page-index-intro-text" data-home-intro-text aria-live="polite" hidden />
      ) : null
    }

    <footer class="site-chrome site-footer" data-site-chrome>
      {
        home?.logo ? (
          <SanityImage image={home.logo} altFallback="Transmoderna" width={480} />
        ) : (
          <p>Transmoderna</p>
        )
      }
    </footer>
  </div>

  <script>
    import { initHomeIntro } from '../scripts/home-intro.ts';
    initHomeIntro();
  </script>
</BaseLayout>
