---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentFadeOverlay from '../../components/ContentFadeOverlay.astro';
import PodcastPlayerBar from '../../components/podcast/PodcastPlayerBar.astro';
import { getPodcastsPage } from '../../lib/sanity';
import '../../styles/pages/podcasts.css';

const podcastsPage = await getPodcastsPage();
const podcasts = podcastsPage?.podcasts ?? [];
---

<BaseLayout title="Podcasts — Transmoderna">
  <main class="page-podcasts">
    <div class="page-podcasts-inner" data-podcast-root transition:animate="none">
      <audio data-podcast-audio preload="none"></audio>

      {
        podcasts.length === 0 ? (
          <p class="page-podcasts-empty">No podcasts yet.</p>
        ) : (
          <ul class="page-podcasts-list">
            {
              podcasts.map((podcast) => (
                <li class="page-podcasts-item">
                  <PodcastPlayerBar podcast={podcast} variant="index" />
                </li>
              ))
            }
          </ul>
        )
      }

      <ContentFadeOverlay />
    </div>
  </main>
</BaseLayout>
