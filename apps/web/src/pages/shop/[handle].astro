---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductBuy from '../../components/shop/ProductBuy.astro';
import ShopBackground from '../../components/shop/ShopBackground.astro';
import ShopBottomBar from '../../components/shop/ShopBottomBar.astro';
import ShopProductToolbar from '../../components/shop/ShopProductToolbar.astro';
import { getShopProductByHandle, productHandle, productImageUrl } from '../../lib/shop';
import { fetchProductStorefrontDataByHandle } from '../../lib/shopify-storefront';
import '../../styles/pages/shop.css';

export const prerender = false;

const { handle } = Astro.params;
if (!handle || handle === 'cart') {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const product = await getShopProductByHandle(handle);
if (!product) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const title = product.store?.title ?? 'Product';
const slug = productHandle(product) ?? handle;
const fallbackImage = productImageUrl(product);
const storefront = await fetchProductStorefrontDataByHandle(slug);
const variants = storefront?.variants ?? [];
const images =
  storefront?.images.length
    ? storefront.images
    : fallbackImage
      ? [{ url: fallbackImage, altText: title }]
      : [];
const imagesJson = JSON.stringify(images);
const shopifyDomain = import.meta.env.PUBLIC_SHOPIFY_DOMAIN ?? '';
const storefrontToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN ?? '';
const marketCountry = import.meta.env.PUBLIC_SHOPIFY_MARKET_COUNTRY ?? '';

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=300'
);
---

<BaseLayout title={`${title} — Shop — Transmoderna`} hideSiteHeader>
  <main
    class="page-shop page-shop-product"
    data-shop-root
    data-shop-page="product"
    data-shopify-domain={shopifyDomain}
    data-storefront-token={storefrontToken}
    data-market-country={marketCountry}
    data-product-handle={slug}
    data-product-images={imagesJson}
    data-variants-truncated={storefront?.variantsTruncated ? 'true' : 'false'}
  >
    <ShopBackground />

    <ShopProductToolbar title={title} />

    <div class="page-shop-product-layout">
      <div class="page-shop-product-media" data-product-media>
        {
          images.length > 0 ? (
            <div
              class="page-shop-product-media-track"
              data-product-media-track
              tabindex={images.length > 1 ? 0 : undefined}
              role="region"
              aria-roledescription="carousel"
              aria-label="Product images"
            >
              {images.map((image, index) => (
                <figure
                  class:list={['page-shop-product-media-slide', { 'is-active': index === 0 }]}
                  data-product-media-slide
                  data-image-index={index}
                  aria-hidden={index !== 0 ? 'true' : 'false'}
                >
                  <img
                    src={image.url}
                    alt={image.altText ?? title}
                    data-product-slide
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </figure>
              ))}
            </div>
          ) : null
        }
      </div>

      <div class="page-shop-product-panel">
        <ProductBuy product={product} variants={variants} options={storefront?.options} />
      </div>

      <aside class="page-shop-product-sidebar" aria-label="Product images">
        {images.map((image, index) => (
          <button
            type="button"
            class="page-shop-product-thumb"
            data-product-thumb
            data-image-index={index}
            data-image-url={image.url}
            aria-current={index === 0 ? 'true' : 'false'}
            aria-label={`View image ${index + 1}`}
          >
            <img src={image.url} alt={image.altText ?? title} loading="lazy" />
          </button>
        ))}
      </aside>
    </div>

    <ShopBottomBar />
  </main>
</BaseLayout>
