---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopBackground from '../../components/shop/ShopBackground.astro';
import ShopBottomBar from '../../components/shop/ShopBottomBar.astro';
import ShopProductCard from '../../components/shop/ShopProductCard.astro';
import { getShopPage } from '../../lib/shop';
import '../../styles/pages/shop.css';

const shop = await getShopPage();
const products = shop?.products ?? [];
const readToken = import.meta.env.SANITY_API_READ_TOKEN?.trim();
const hasReadToken = Boolean(readToken);
const shopifyDomain = import.meta.env.PUBLIC_SHOPIFY_DOMAIN ?? '';
const storefrontToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN ?? '';
const marketCountry = import.meta.env.PUBLIC_SHOPIFY_MARKET_COUNTRY ?? '';
const initialQuery = Astro.url.searchParams.get('q')?.trim() ?? '';

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=60, stale-while-revalidate=300'
);
---

<BaseLayout title="Shop — Transmoderna">
  <main
    class="page-shop page-shop-plp"
    data-shop-root
    data-shop-page="index"
    data-shopify-domain={shopifyDomain}
    data-storefront-token={storefrontToken}
    data-market-country={marketCountry}
    data-initial-search={initialQuery}
  >
    <ShopBackground />

    {
      products.length === 0 ? (
        <div class="page-shop-token-notice">
          <p>
            No products were returned from Sanity. This project’s dataset is not readable without an
            API token (anonymous queries return 0 documents).
          </p>
          {!hasReadToken ? (
            <p>
              Add a <strong>Viewer</strong> token to <code>apps/web/.env</code> as{' '}
              <code>SANITY_API_READ_TOKEN=sk…</code> (no quotes), save the file, then restart{' '}
              <code>npm run dev:web</code>.
            </p>
          ) : (
            <p>
              <code>SANITY_API_READ_TOKEN</code> is set — restart <code>npm run dev:web</code> if
              you just added it. For production, add the same variable in Netlify env settings.
            </p>
          )}
        </div>
      ) : (
        <>
          <div class="page-shop-grid" data-shop-grid>
            {products.map((product) => (
              <ShopProductCard product={product} />
            ))}
          </div>
          <p class="page-shop-empty" data-shop-search-empty hidden>
            No products match.
          </p>
        </>
      )
    }

    <ShopBottomBar initialQuery={initialQuery} />
  </main>
</BaseLayout>
