---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getExhibitionsPage, imageAlt, urlForSanityImage } from '../../lib/sanity';
import { EXHIBITIONS_VIEW_STORAGE_KEY } from '../../lib/exhibitions-view';
import '../../styles/pages/exhibitions.css';

const exhibitionsPage = await getExhibitionsPage();
const exhibitions = exhibitionsPage?.exhibitions ?? [];
const thumbnailBackgroundSrc = urlForSanityImage(exhibitionsPage?.thumbnailBackgroundImage, {
  width: 2400
});
const thumbnailBackgroundAlt = imageAlt(
  exhibitionsPage?.thumbnailBackgroundImage,
  'Exhibitions thumbnail view background'
);
const fullPageBackgroundSrc = urlForSanityImage(exhibitionsPage?.fullBackgroundImage, {
  width: 2400
});
const fullPageBackgroundAlt = imageAlt(
  exhibitionsPage?.fullBackgroundImage,
  'Exhibitions full view background'
);

const thumbnailViewItems = exhibitions.map((item) => {
  const title = item.title ?? 'Exhibition';
  return {
    title,
    href: item.slug?.current ? `/exhibitions/${item.slug.current}` : null,
    thumbSrc: urlForSanityImage(item.thumbnailImage, { width: 1200 }),
    thumbAlt: imageAlt(item.thumbnailImage, title)
  };
});

const fullViewItems = exhibitions.map((item) => {
  const title = item.title ?? 'Exhibition';
  return {
    title,
    href: item.slug?.current ? `/exhibitions/${item.slug.current}` : null,
    bgSrc: urlForSanityImage(item.fullImage, { width: 2400 }),
    bgAlt: imageAlt(item.fullImage, title)
  };
});

const thumbnailSlotOffsets = [-2, -1, 0, 1, 2];
const fullLoopCopies = 3;

function wrapExhibitionIndex(index: number, length: number): number {
  return ((index % length) + length) % length;
}

const fullLoopItems =
  fullViewItems.length > 0
    ? Array.from({ length: fullLoopCopies }, () => fullViewItems).flat()
    : [];
---

<BaseLayout title="Exhibitions — Transmoderna">
  <script
    slot="head"
    is:inline
    define:vars={{ storageKey: EXHIBITIONS_VIEW_STORAGE_KEY }}
  >
    try {
      const mode = localStorage.getItem(storageKey);
      document.documentElement.dataset.exhibitionsView =
        mode === 'thumbnail' ? 'thumbnail' : 'full';
      if (mode !== 'thumbnail') {
        document.documentElement.classList.add('exhibitions-list-pending');
      }
    } catch (e) {
      document.documentElement.dataset.exhibitionsView = 'full';
      document.documentElement.classList.add('exhibitions-list-pending');
    }
  </script>
  <style is:inline>
    .page-exhibitions-full {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }

    .page-exhibitions-full-slide {
      opacity: 0;
      visibility: hidden;
    }

    .page-exhibitions-full.is-ready {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .page-exhibitions-full.is-ready .page-exhibitions-full-slide {
      visibility: visible;
    }
  </style>

  <main class="page-exhibitions" data-exhibitions-page data-exhibitions-view="full">
    {
      thumbnailBackgroundSrc ? (
        <div
          class="page-exhibitions-page-bg page-exhibitions-page-bg--thumbnail"
          aria-hidden="true"
        >
          <img
            src={thumbnailBackgroundSrc}
            alt={thumbnailBackgroundAlt}
            width={2400}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      ) : null
    }
    {
      fullPageBackgroundSrc ? (
        <div class="page-exhibitions-page-bg page-exhibitions-page-bg--full" aria-hidden="true">
          <img
            src={fullPageBackgroundSrc}
            alt={fullPageBackgroundAlt}
            width={2400}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      ) : null
    }

    {
      exhibitions.length === 0 ? (
        <p>No exhibitions yet.</p>
      ) : (
        <>
          <div
            class="page-exhibitions-thumbnail"
            data-exhibitions-thumbnail
            data-exhibitions-items={JSON.stringify(thumbnailViewItems)}
          >
            <p class="sr-only" data-exhibitions-thumb-live aria-live="polite" aria-atomic="true">
              {thumbnailViewItems[0]?.title}
            </p>

            <div
              class="page-exhibitions-thumbnail-scroller"
              data-exhibitions-thumbnail-scroller
              tabindex="0"
            >
              <ul class="page-exhibitions-thumbnail-track" data-exhibitions-thumbnail-track>
                {
                  thumbnailSlotOffsets.map((offset) => {
                    const item =
                      thumbnailViewItems[wrapExhibitionIndex(offset, thumbnailViewItems.length)];
                    const isActive = offset === 0;

                    return (
                      <li
                        class:list={[
                          'page-exhibitions-thumbnail-slide',
                          { 'is-active': isActive }
                        ]}
                        data-exhibitions-thumb-slot={offset}
                      >
                        {item?.href ? (
                          <a class="page-exhibitions-thumbnail-slide-link" href={item.href}>
                            <figure class="page-exhibitions-thumbnail-slide-figure">
                              {
                                item.thumbSrc ? (
                                  <img
                                    class="page-exhibitions-thumbnail-slide-image"
                                    src={item.thumbSrc}
                                    alt={item.thumbAlt}
                                    width={1200}
                                    loading={isActive ? 'eager' : 'lazy'}
                                    decoding="async"
                                  />
                                ) : null
                              }
                              <figcaption class="page-exhibitions-thumbnail-slide-title">
                                {item.title}
                              </figcaption>
                            </figure>
                          </a>
                        ) : (
                          <figure class="page-exhibitions-thumbnail-slide-figure">
                            {
                              item?.thumbSrc ? (
                                <img
                                  class="page-exhibitions-thumbnail-slide-image"
                                  src={item.thumbSrc}
                                  alt={item.thumbAlt}
                                  width={1200}
                                  loading={isActive ? 'eager' : 'lazy'}
                                  decoding="async"
                                />
                              ) : null
                            }
                            <figcaption class="page-exhibitions-thumbnail-slide-title">
                              {item?.title}
                            </figcaption>
                          </figure>
                        )}
                      </li>
                    );
                  })
                }
                <li
                  class="page-exhibitions-thumbnail-slide"
                  data-exhibitions-thumb-slot="enter-right"
                  hidden
                  aria-hidden="true"
                >
                  <figure class="page-exhibitions-thumbnail-slide-figure">
                    <img
                      class="page-exhibitions-thumbnail-slide-image"
                      alt=""
                      decoding="async"
                    />
                  </figure>
                </li>
                <li
                  class="page-exhibitions-thumbnail-slide"
                  data-exhibitions-thumb-slot="enter-left"
                  hidden
                  aria-hidden="true"
                >
                  <figure class="page-exhibitions-thumbnail-slide-figure">
                    <img
                      class="page-exhibitions-thumbnail-slide-image"
                      alt=""
                      decoding="async"
                    />
                  </figure>
                </li>
              </ul>
            </div>
          </div>

          <div
            class="page-exhibitions-full"
            data-exhibitions-full
            data-exhibitions-items={JSON.stringify(fullViewItems)}
          >
            <p class="sr-only" data-exhibitions-live aria-live="polite" aria-atomic="true">
              {fullViewItems[0]?.title}
            </p>

            <div class="page-exhibitions-full-bg" aria-hidden="true">
              {
                fullViewItems[0]?.bgSrc ? (
                  <img
                    class="is-active"
                    data-exhibitions-bg-layer="0"
                    src={fullViewItems[0].bgSrc}
                    alt={fullViewItems[0].bgAlt}
                    decoding="async"
                  />
                ) : (
                  <img data-exhibitions-bg-layer="0" alt="" decoding="async" />
                )
              }
              <img data-exhibitions-bg-layer="1" alt="" decoding="async" />
            </div>

            <div
              class="page-exhibitions-full-scroller"
              data-exhibitions-full-scroller
              tabindex="0"
            >
              <ul class="page-exhibitions-full-track" data-exhibitions-full-track>
                {
                  fullLoopItems.map((item, loopIndex) => {
                    const itemIndex = wrapExhibitionIndex(loopIndex, fullViewItems.length);

                    return (
                      <li
                        class="page-exhibitions-full-slide"
                        data-exhibitions-loop-index={loopIndex}
                        data-exhibitions-item-index={itemIndex}
                      >
                        {item?.href ? (
                          <a class="page-exhibitions-full-slide-link">
                            <span class="page-exhibitions-full-slide-title">{item.title}</span>
                          </a>
                        ) : (
                          <span class="page-exhibitions-full-slide-title">{item?.title}</span>
                        )}
                      </li>
                    );
                  })
                }
              </ul>
            </div>
          </div>
        </>
      )
    }
  </main>
  <div class="page-exhibitions-view-toggle" role="group" aria-label="Exhibitions view mode">
    <button type="button" data-exhibitions-view-toggle="thumbnail" aria-pressed="false">
    </button>
    <button type="button" data-exhibitions-view-toggle="full" aria-pressed="true">
    </button>
  </div>
</BaseLayout>
