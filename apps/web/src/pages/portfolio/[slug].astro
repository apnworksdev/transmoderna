---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioMedia from '../../components/PortfolioMedia.astro';
import { getPortfolioItemBySlug } from '../../lib/sanity';
import '../../styles/pages/portfolio.css';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const item = await getPortfolioItemBySlug(slug);

if (!item) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const pageTitle = item.title ? `${item.title} — Transmoderna` : 'Portfolio — Transmoderna';
const mediaItems = item.media ?? [];
---

<BaseLayout title={pageTitle} hideSiteHeader>
  <main class="page-portfolio-detail">
    <div class="page-portfolio-detail-toolbar">
      <div class="page-portfolio-detail-title-wrap">
        <h1 class="page-portfolio-detail-title">{item.title}</h1>
      </div>

      <a class="page-portfolio-detail-close site-header-pill" href="/portfolio">Close</a>
    </div>

    {
      mediaItems.length > 0 ? (
        <div class="page-portfolio-detail-media">
          {mediaItems.map((media, index) => (
            <PortfolioMedia
              media={media}
              title={mediaItems.length > 1 ? `${item.title ?? 'Portfolio'} — ${index + 1}` : (item.title ?? 'Portfolio')}
            />
          ))}
        </div>
      ) : null
    }
  </main>
</BaseLayout>
